<definitions id="test">
  <process id="callActivityEscalationBoundaryTest" isExecutable="true">
    <startEvent id="startEvent">
      <outgoing>f1</outgoing>
    </startEvent>
    <sequenceFlow id="f1" sourceRef="startEvent" targetRef="callActivity" />
    <callActivity id="callActivity">
      <incoming>f1</incoming>
      <outgoing>f2</outgoing>
    </callActivity>
    <sequenceFlow id="f2" sourceRef="callActivity" targetRef="endEvent" />
    <endEvent id="endEvent">
      <incoming>f2</incoming>
    </endEvent>
    <boundaryEvent id="escalationBoundaryEventNonInterrupting" cancelActivity="false" attachedToRef="callActivity">
      <outgoing>f4</outgoing>
      <escalationEventDefinition id="escalationBoundaryEventNonInterruptingDefinition" escalationRef="testEscalationNonInterrupting" />
    </boundaryEvent>
    <sequenceFlow id="f4" sourceRef="escalationBoundaryEventNonInterrupting" targetRef="nonInterruptingEscalationEnd" />
    <endEvent id="nonInterruptingEscalationEnd">
      <incoming>f4</incoming>
    </endEvent>
    <boundaryEvent id="escalationBoundaryEvent" attachedToRef="callActivity">
      <outgoing>f5</outgoing>
      <escalationEventDefinition id="escalationBoundaryEventDefinition" escalationRef="testEscalation" />
    </boundaryEvent>
    <sequenceFlow id="f5" sourceRef="escalationBoundaryEvent" targetRef="escalationEnd" />
    <endEvent id="escalationEnd">
      <incoming>f5</incoming>
    </endEvent>
  </process>
  <escalation id="testEscalationNonInterrupting" name="testEscalationNonInterruptingName" escalationCode="testEscalationNonInterruptingCode" />
  <escalation id="testEscalation" name="testEscalationName" escalationCode="testEscalationCode" />
</definitions>
