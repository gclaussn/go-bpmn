<definitions id="test">
  <process id="callActivityErrorBoundaryTest" isExecutable="true">
    <startEvent id="startEvent">
      <outgoing>f1</outgoing>
    </startEvent>
    <sequenceFlow id="f1" sourceRef="startEvent" targetRef="callActivity" />
    <callActivity id="callActivity">
      <incoming>f1</incoming>
      <outgoing>f2</outgoing>
    </callActivity>
    <sequenceFlow id="f2" sourceRef="callActivity" targetRef="endEvent" />
    <endEvent id="endEvent">
      <incoming>f2</incoming>
    </endEvent>
    <boundaryEvent id="errorBoundaryEvent" attachedToRef="callActivity">
      <outgoing>f3</outgoing>
      <errorEventDefinition id="errorEventDefinition" errorRef="testError" />
    </boundaryEvent>
    <sequenceFlow id="f3" sourceRef="errorBoundaryEvent" targetRef="errorEnd" />
    <endEvent id="errorEnd">
      <incoming>f3</incoming>
    </endEvent>
  </process>
  <error id="testError" name="testErrorName" errorCode="testErrorCode" />
</definitions>
