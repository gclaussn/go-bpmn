<definitions id="test">
  <process id="userTaskErrorBoundaryTest" isExecutable="true">
    <startEvent id="startEvent">
      <outgoing>f1</outgoing>
    </startEvent>
    <sequenceFlow id="f1" sourceRef="startEvent" targetRef="userTask" />
    <userTask id="userTask">
      <incoming>f1</incoming>
      <outgoing>f2</outgoing>
    </userTask>
    <sequenceFlow id="f2" sourceRef="userTask" targetRef="endEvent" />
    <endEvent id="endEvent">
      <incoming>f2</incoming>
    </endEvent>
    <boundaryEvent id="errorBoundaryEvent" attachedToRef="userTask">
      <outgoing>f3</outgoing>
      <errorEventDefinition id="errorBoundaryEventDefinition" errorRef="testError" />
    </boundaryEvent>
    <sequenceFlow id="f3" sourceRef="errorBoundaryEvent" targetRef="errorEnd" />
    <endEvent id="errorEnd">
      <incoming>f3</incoming>
    </endEvent>
  </process>
  <error id="testError" name="testErrorName" errorCode="testErrorCode" />
</definitions>
